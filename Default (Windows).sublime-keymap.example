[
    // MarkdownPreviewEnhanced example key bindings — Windows.
    // Copy this file to "Default (Windows).sublime-keymap" (drop the ".example")
    // to enable these shortcuts, or define your own.
    { "keys": ["ctrl+shift+m"], "command": "markdown_preview_enhanced_toggle" },
    { "keys": ["ctrl+shift+alt+m"], "command": "markdown_preview_enhanced_close" },
    { "keys": ["ctrl+shift+e"], "command": "markdown_preview_enhanced_export_html" },
]

[
    // MarkdownPreviewEnhanced example key bindings — macOS.
    // Copy this file to "Default (OSX).sublime-keymap" (drop the ".example")
    // to enable these shortcuts, or define your own.
    { "keys": ["super+shift+m"], "command": "markdown_preview_enhanced_toggle" },
    { "keys": ["super+shift+alt+m"], "command": "markdown_preview_enhanced_close" },
    { "keys": ["super+shift+e"], "command": "markdown_preview_enhanced_export_html" },
]
